{
  "name": "clipforge",
  "version": "1.0.0",
  "description": "⚡ AI-powered CLI tool to turn long YouTube videos into viral Shorts — batch download, smart crop, watermark, and compile. Forked from FullStackHarman/youtube-clipper.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "server": "node server/index.js",
    "start": "concurrently \"npm run dev\" \"npm run server\"",
    "test": "vitest run",
    "cli": "node cli.js"
  },
  "bin": {
    "clipforge": "./cli.js"
  },
  "keywords": [
    "youtube",
    "shorts",
    "video-editor",
    "ffmpeg",
    "cli",
    "content-creator",
    "automation",
    "gemini-ai",
    "tiktok",
    "reels"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ieproject-app/clipforge.git"
  },
  "author": "Iwan Efendi",
  "license": "MIT",
  "dependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.0.0",
    "nouislider": "^15.8.1",
    "ora": "^9.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "uuid": "^11.1.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "fast-check": "^3.23.2",
    "vitest": "^2.1.9"
  }
}
